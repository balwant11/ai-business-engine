  "website_content": {
    "homepage": {
      "hero_section": {
        "title": "Shradha Export Mill: Your Premier Source for Quality Bedsheet Fabrics",
        "subtitle": "Experience the finest in bedsheet textiles, blending premium quality with unparalleled design variety for over 30 years.",
        "button_text": "Explore Our Collection"
      },
      "introduction": {
        "heading": "Crafting Comfort and Style for Decades",
        "paragraph_1": "At Shradha Export Mill, we are proud to be Ahmedabad's leading manufacturer and supplier of exceptional bedsheet fabrics. With a rich heritage spanning over 30 years, we have consistently delivered premium quality, durability, and a breathtaking array of designs to our esteemed clients.",
        "paragraph_2": "Our dedication to crafting fabrics that transform spaces and elevate comfort is unwavering. We offer an extensive collection of bedsheet materials and ready sets, ensuring every customer finds the perfect blend of style, quality, and value."
      }
    },
    "products_services_page": {
      "heading": "Discover Our Exquisite Fabric Collections",
      "introduction": "Shradha Export Mill specializes in providing a comprehensive range of bedsheet fabrics and ready sets that meet the diverse needs of retailers, wholesalers, and designers. Our commitment to innovation, quality, and variety makes us the preferred choice in the market.",
      "service_offerings": [
        {
          "title": "Premium Bed Sheet Fabrics",
          "description": "Explore our vast selection of bedsheet fabrics, renowned for their premium feel, softness, and long-lasting durability. From luxurious cottons to blended materials, we offer options that promise comfort and elegance."
        },
        {
          "title": "Vibrant Designs & Colors",
          "description": "Dive into a world of vibrant designs, intricate patterns, and a spectrum of colors. Our collection is curated to include the latest trends and timeless classics, ensuring a perfect match for every aesthetic."
        },
        {
          "title": "Ready Bedsheet Sets",
          "description": "For convenience and style, choose from our expertly crafted ready bedsheet sets. Designed with precision and attention to detail, these sets offer an immediate solution for beautiful bedding."
        },
        {
          "title": "Custom Manufacturing & Bulk Orders",
          "description": "Leverage our extensive manufacturing capabilities for custom orders and large-scale requirements. We are equipped to handle bulk production with a commitment to timely delivery and consistent quality."
        }
      ]
